# ==============================================================================
# Billie Global BR — Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para ".env" e preencha com suas credenciais reais.
# NUNCA cometa o arquivo ".env" no Git. Ele já está no .gitignore.
# NUNCA cole chaves reais em chats, issues, ou documentos compartilhados.
# ==============================================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
SITE_URL=https://billieglobalbr.com.br

# --- Telegram Bot API ---
# Crie um bot com o @BotFather no Telegram e adicione-o como ADMIN do canal.
TELEGRAM_BOT_TOKEN=coloque_aqui_o_token_do_bot
TELEGRAM_CHANNEL_USERNAME=@billieglobalbr

# --- Provedor de IA ---
# Escolha qual IA será usada para organizar as notícias: "openai" ou "gemini"
AI_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=coloque_aqui_sua_chave_openai
OPENAI_MODEL=gpt-4o-mini

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=coloque_aqui_sua_chave_gemini
GEMINI_MODEL=gemini-1.5-flash

# --- Firebase (Realtime Database + Storage + Admin SDK) ---
# Gere a chave em: Console Firebase > Configurações do projeto > Contas de serviço
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
# Nome do bucket do Firebase Storage (mesmo valor do campo "storageBucket"
# em frontend/js/firebase-config.js). Usado para hospedar permanentemente
# as imagens/vídeos das notícias, já que os links do Telegram expiram.
# Ex: billie-global-br-feed.firebasestorage.app
FIREBASE_STORAGE_BUCKET=

# --- CORS (opcional) ---
# Domínios que podem consumir a API. Separe múltiplos por vírgula.
ALLOWED_ORIGINS=http://localhost:5500,https://billieglobalbr.com.br
